{
  "name": "fastapi-dev",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "server",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy",
        "ms-python.isort",
        "chunsen.bracket-select",
        "usernamehw.errorlens"
      ],
      "settings": {
        "python.analysis.autoImportCompletions": true,
        "editor.quickSuggestions": {
          "other": true
        }
      }
    }
  }
}